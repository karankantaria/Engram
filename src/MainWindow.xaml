<Window x:Class="Engram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="engram"
        Height="760" Width="1180"
        MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F15"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Foreground" Value="#5C6675" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#19212D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeButtonClose" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#19212D" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom terminal-style title bar -->
            <Grid Grid.Row="0" Background="#0B0F15" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="LogoImg" Height="16" Margin="8,0,0,0"
                           VerticalAlignment="Center" Visibility="Collapsed"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock x:Name="TitleText" Text="  engram — second brain"
                               Foreground="#5C6675" FontFamily="Cascadia Mono, Consolas, monospace"
                               FontSize="12" VerticalAlignment="Center" Margin="2,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Click="Minimize_Click" Style="{StaticResource ChromeButton}" />
                    <Button Content="▢" Click="Maximize_Click" Style="{StaticResource ChromeButton}" />
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource ChromeButtonClose}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" x:Name="WebHost" AllowDrop="True"
                  DragEnter="WebHost_DragEnter" DragOver="WebHost_DragEnter"
                  DragLeave="WebHost_DragLeave" Drop="WebHost_Drop">
                <wv2:WebView2 x:Name="Web" />
                <Border x:Name="DropOverlay" Visibility="Collapsed" IsHitTestVisible="False"
                        Background="#E60B0F15" BorderBrush="#43E08B" BorderThickness="2" Margin="28">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⇪" FontSize="44" Foreground="#43E08B" HorizontalAlignment="Center" />
                        <TextBlock Text="drop files to import" Foreground="#C7D0DC"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="16"
                                   Margin="0,10,0,0" HorizontalAlignment="Center" />
                        <TextBlock Text="markdown · text · pdf — auto-split into notes" Foreground="#5C6675"
                                   FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                                   Margin="0,4,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
