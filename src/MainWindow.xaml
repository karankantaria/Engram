<Window x:Class="Engram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="engram"
        Height="760" Width="1180"
        MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#0B0E14"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Foreground" Value="#5C6370" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#1F2430" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeButtonClose" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1F2430" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="28" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom terminal-style title bar -->
            <Grid Grid.Row="0" Background="#0B0E14" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="  engram — second brain"
                           Foreground="#5C6370" FontFamily="Cascadia Mono, Consolas, monospace"
                           FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="—" Click="Minimize_Click" Style="{StaticResource ChromeButton}" />
                    <Button Content="▢" Click="Maximize_Click" Style="{StaticResource ChromeButton}" />
                    <Button Content="✕" Click="Close_Click" Style="{StaticResource ChromeButtonClose}" />
                </StackPanel>
            </Grid>

            <wv2:WebView2 Grid.Row="1" x:Name="Web" />
        </Grid>
    </Border>
</Window>
